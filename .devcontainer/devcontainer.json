{
  "name": "TS Proj Dev Container",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.tabSize": 4
      },
      "extensions": [
        "esbenp.prettier-vscode",
        "vivaxy.vscode-conventional-commits"
      ]
    }
  },
  "remoteUser": "root"
}
